<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd" >

<mapper namespace="com.rememberme.dunoesanchaeg.mapper.MemberMapper">

    <resultMap id="MemberResultMap" type="com.rememberme.dunoesanchaeg.domain.Member">
        <id property="memberId" column="member_id"/>
        <result property="kakaoId" column="kakao_id"/>
        <result property="email" column="email"/>
        <result property="role" column="role"/>
        <result property="name" column="name"/>
        <result property="birthDate" column="birth_date"/>
        <result property="phone" column="phone"/>
        <result property="guardianEmail" column="guardian_email"/>
        <result property="guardianPhone" column="guardian_phone"/>
        <result property="guardianConsent" column="guardian_consent"/>
        <result property="isProfileCompleted" column="is_profile_completed"/>
        <result property="userStatus" column="user_status"/>
        <result property="isHighContrast" column="is_high_contrast"/>
        <result property="fontSize" column="font_size"/>
        <result property="totalRoutineCount" column="total_routine_count"/>
        <result property="lastLoginAt" column="last_login_at"/>
        <result property="createdAt" column="created_at"/>
        <result property="updatedAt" column="updated_at"/>
        <result property="deletedAt" column="deleted_at"/>
    </resultMap>

    <!--  카카오 아이디와 일치하는 멤버의 데이터를 가져옴  -->
    <select id="findByKakaoId" resultMap="MemberResultMap" parameterType="String">
        SELECT member_id,
               kakao_id,
               email,
               role,
               name,
               birth_date,
               phone,
               guardian_email,
               guardian_phone,
               guardian_consent,
               is_profile_completed,
               user_status,
               is_high_contrast,
               font_size,
               total_routine_count,
               last_login_at,
               created_at,
               updated_at,
               deleted_at
        FROM member
        WHERE kakao_id = #{kakaoId}
    </select>

    <!-- request부분으로 받아와서 저장-->
    <insert id="insertMember" useGeneratedKeys="true" keyProperty="memberId" parameterType="com.rememberme.dunoesanchaeg.domain.Member">
        INSERT INTO member (
           kakao_id,
           email
        )VALUES (
           #{kakaoId},
           #{email}
                )
    </insert>

    <!-- updateLastLoginAt -->
    <update id="updateLastLoginAt" parameterType="Long">
        UPDATE member
        SET last_login_at = NOW()
        WHERE member_id = #{memberId}
    </update>

</mapper>